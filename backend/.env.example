# Backend Environment Variables

# Node environment (development, production)
NODE_ENV=development

# Server port
PORT=3000

# Database connection string (PostgreSQL)
# Development: postgresql://postgres:postgres@db:5432/compra_coletiva
# Production (Railway): Use reference variable ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://postgres:postgres@db:5432/compra_coletiva

# CORS origins - URLs do frontend (aceita múltiplos domínios separados por vírgula)
# Protocolo será adicionado automaticamente:
#   - Domínios locais (localhost, 127.0.0.1): sempre http://
#   - Domínios remotos: https:// em produção, http:// em desenvolvimento
#   - Se especificar o protocolo manualmente (http:// ou https://), será usado como está
#
# Exemplos:
#   Single origin: localhost:5173
#   Multiple origins: localhost:5173,your-domain.com
#   With protocol: http://localhost:5173,https://production-domain.com
#
# Development: localhost:5173
# Production (Railway): localhost:5173,your-frontend.up.railway.app
CORS_ORIGIN=localhost:5173

# Google OAuth (backend)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
FRONTEND_URL=http://localhost:5173

# Image Storage Configuration
# Option 1: AWS S3 (recommended for production)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_S3_BUCKET=your-bucket-name
# AWS_S3_REGION=us-east-1

# Option 2: Railway Volume (good for small/medium apps)
# UPLOAD_DIR=/app/data  # Set this to the Railway volume mount path

# JWT / Auth
JWT_ACCESS_SECRET=your-access-secret
JWT_REFRESH_SECRET=your-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=365d
# Security: never expose reset token in API response outside controlled local debugging
EXPOSE_RESET_TOKEN_IN_RESPONSE=false

# Legal / LGPD versioning
LEGAL_TERMS_VERSION=2026-03-12
LEGAL_PRIVACY_VERSION=2026-03-12
LEGAL_SALES_DISCLAIMER_VERSION=2026-03-12

# Optional secret for public buyer aliases (transparency endpoints)
PUBLIC_ALIAS_SECRET=your-public-alias-secret

# Data retention scheduler (milliseconds / days)
LEGAL_RETENTION_INTERVAL_MS=86400000
PASSWORD_RESET_TOKEN_RETENTION_DAYS=30
LEGAL_ACCEPTANCE_LOG_RETENTION_DAYS=1825
