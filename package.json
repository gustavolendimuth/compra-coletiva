{
  "name": "compra-coletiva",
  "version": "1.0.0",
  "description": "Sistema de gerenciamento de compras coletivas",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "docker-compose up",
    "build": "npm run build --workspaces",
    "clean": "npm run clean --workspaces",
    "fix:prisma-engine-perms": "node scripts/fix-prisma-engine-permissions.js",
    "postinstall": "npm run fix:prisma-engine-perms",
    "migrate:deploy:container": "docker compose exec backend npx prisma migrate deploy --schema prisma/schema.prisma",
    "migrate:deploy:host": "DATABASE_URL=postgresql://postgres:postgres@localhost:5432/compra_coletiva npm exec --workspace=backend prisma migrate deploy"
  },
  "keywords": [
    "compra-coletiva",
    "gestao",
    "pedidos"
  ],
  "author": "",
  "license": "MIT"
}
